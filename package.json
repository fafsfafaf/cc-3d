{
  "name": "cc-3d",
  "version": "1.0.0",
  "description": "3D web dashboard for live Claude Code session monitoring",
  "type": "module",
  "bin": {
    "cc-3d": "./bin/cc-3d.mjs"
  },
  "scripts": {
